# ============================================================
# DATASHIELD Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME=DATASHIELD
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_64_CHARS

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://datashield:securepassword@localhost:5432/datashield
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI/ML Services ---
AI_CLASSIFICATION_THRESHOLD=0.75
AI_ANOMALY_THRESHOLD=0.80
AI_MODEL_PATH=./models

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/datashield.log

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
