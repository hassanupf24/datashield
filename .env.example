# DATASHIELD Environment Variables
# Copy to .env and update values for your environment

# --- Database ---
POSTGRES_PASSWORD=securepassword

# --- Redis ---
REDIS_PASSWORD=redispassword

# --- Backend ---
APP_SECRET_KEY=change-this-to-64-char-random-string-for-production
JWT_SECRET_KEY=change-this-to-64-char-random-jwt-secret-for-production

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
